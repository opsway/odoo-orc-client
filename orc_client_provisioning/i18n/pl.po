#. module: orc_client_provisioning
#. odoo-python
#: code:addons/orc_client_provisioning/controllers/orc_sso.py:0
msgid ""
"The addon's token was revoked or replaced. Ask a consultant to mint a new "
"one, then paste it into System Parameters → orc.org_token."
msgstr ""
"Token dodatku został odwołany lub zastąpiony. Poproś konsultanta o "
"wygenerowanie nowego, a następnie wklej go w Parametrach systemu → "
"orc.org_token."

#. module: orc_client_provisioning
#. odoo-python
#: code:addons/orc_client_provisioning/controllers/orc_sso.py:0
msgid "Token is pinned to a different environment"
msgstr "Token jest przypisany do innego środowiska"

#. module: orc_client_provisioning
#. odoo-python
#: code:addons/orc_client_provisioning/controllers/orc_sso.py:0
msgid ""
"Mint a token for this Odoo instance specifically (stage vs prod tokens are "
"not interchangeable) and update orc.org_token."
msgstr ""
"Wygeneruj token dedykowany tej instancji Odoo (tokeny stage i prod nie są "
"wymienne) i zaktualizuj orc.org_token."

#. module: orc_client_provisioning
