<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Three crons:
          * sync (hourly) - reconcile + role-drift rotation
          * maintenance (daily 02:15) - rotate keys past expiry
          * access log prune (daily 03:00) - delete old access-log rows

        numbercall=-1: unlimited firings; without it the upstream
        default of 1 deactivates the cron after the first run.
    -->

    <record id="ir_cron_orc_sync" model="ir.cron">
        <field name="name">ORC: sync roles and reconcile</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">model._cron_orc_sync()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="nextcall"
               eval="(DateTime.now() + relativedelta(minutes=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_orc_maintenance" model="ir.cron">
        <field name="name">ORC: daily maintenance</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">model._cron_orc_maintenance()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall"
               eval="(DateTime.now().replace(hour=2, minute=15, second=0, microsecond=0) + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_orc_access_log_prune" model="ir.cron">
        <field name="name">ORC: prune access log</field>
        <field name="model_id" ref="model_orc_api_access_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_orc_access_log_prune()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall"
               eval="(DateTime.now().replace(hour=3, minute=0, second=0, microsecond=0) + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active" eval="True"/>
    </record>
</odoo>
