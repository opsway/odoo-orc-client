<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_orc" model="ir.ui.view">
        <field name="name">res.users.form.orc</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Odoo Resolution Center" name="orc_access" groups="orc_client_provisioning.group_orc_manager">
                    <group>
                        <field name="orc_enabled"/>
                        <field name="orc_is_manager" invisible="1"/>
                        <div invisible="not orc_is_manager" class="text-muted">
                            This user is an ORC manager — provisioned as ORC admin.
                        </div>
                        <field name="orc_user_id" readonly="1" invisible="not orc_enabled"/>
                        <field name="orc_provisioned_at" readonly="1" invisible="not orc_enabled"/>
                        <field name="orc_last_rotation_at" readonly="1" invisible="not orc_enabled"/>
                        <field name="orc_api_key_id" readonly="1" invisible="not orc_enabled"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_users_tree_orc" model="ir.ui.view">
        <field name="name">res.users.tree.orc</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='login']" position="after">
                <field name="orc_enabled" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
