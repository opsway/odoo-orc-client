<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_orc" model="ir.ui.view">
        <field name="name">res.users.form.orc</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="ORC Access" name="orc_access" groups="orc_client_provisioning.group_orc_manager">
                    <group>
                        <field name="orc_enabled"/>
                        <field name="orc_is_manager" invisible="1"/>
                        <field name="orc_last_sync_at" readonly="1"
                               attrs="{'invisible': [('orc_enabled', '=', False)]}"/>
                        <field name="orc_last_sync_status" widget="badge"
                               decoration-success="orc_last_sync_status == 'ok'"
                               decoration-warning="orc_last_sync_status == 'drift'"
                               decoration-danger="orc_last_sync_status == 'error'"
                               attrs="{'invisible': [('orc_enabled', '=', False)]}"/>
                        <field name="orc_last_sync_message" readonly="1"
                               attrs="{'invisible': [('orc_last_sync_message', '=', False)]}"/>
                        <field name="orc_user_id" readonly="1"
                               attrs="{'invisible': [('orc_enabled', '=', False)]}"/>
                        <field name="orc_provisioned_at" readonly="1"
                               attrs="{'invisible': [('orc_enabled', '=', False)]}"/>
                        <field name="orc_api_key_rotated_at" readonly="1"
                               attrs="{'invisible': [('orc_enabled', '=', False)]}"/>
                        <field name="orc_api_key_expires_at" readonly="1"
                               attrs="{'invisible': [('orc_enabled', '=', False)]}"/>
                    </group>
                    <div attrs="{'invisible': [('orc_enabled', '=', False)]}">
                        <button name="action_orc_view_access_log" type="object"
                                string="View ORC API access log" class="btn-link"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_users_tree_orc" model="ir.ui.view">
        <field name="name">res.users.tree.orc</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='login']" position="after">
                <field name="orc_enabled" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
