<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_orc" model="ir.ui.view">
        <field name="name">res.users.form.orc</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="AI Workplace" name="orc_access" groups="orc_client_provisioning.group_orc_manager">
                    <group>
                        <field name="orc_provisionable" invisible="1"/>
                        <!-- Plan §9 + task 63: the (pinned_org_id, odoo_login)
                             gateway key requires a non-empty login. Empty-login
                             accounts are technically impossible in stock Odoo
                             (login is NOT NULL), but the explicit gate
                             documents the precondition + future-proofs against
                             Odoo versions that relax the constraint. -->
                        <field
                            name="orc_enabled"
                            readonly="not orc_provisionable"
                            help="Requires a non-empty Odoo login."
                        />
                        <field name="orc_is_manager" invisible="1"/>
                        <field name="orc_last_sync_at" readonly="1" invisible="not orc_enabled"/>
                        <field
                            name="orc_last_sync_status"
                            widget="badge"
                            decoration-success="orc_last_sync_status == 'ok'"
                            decoration-warning="orc_last_sync_status == 'drift'"
                            decoration-danger="orc_last_sync_status == 'error'"
                            invisible="not orc_enabled"
                        />
                        <field name="orc_last_sync_message" readonly="1" invisible="not orc_last_sync_message"/>
                        <field name="orc_user_id" readonly="1" invisible="not orc_enabled"/>
                        <field name="orc_provisioned_at" readonly="1" invisible="not orc_enabled"/>
                        <field name="orc_last_rotation_at" readonly="1" invisible="not orc_enabled"/>
                        <field name="orc_api_key_id" readonly="1" invisible="not orc_enabled"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_users_tree_orc" model="ir.ui.view">
        <field name="name">res.users.tree.orc</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='login']" position="after">
                <field name="orc_enabled" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
