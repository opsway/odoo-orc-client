<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_orc_audit_log_tree" model="ir.ui.view">
        <field name="name">orc.audit.log.tree</field>
        <field name="model">orc.audit.log</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false"
                       decoration-success="status=='ok'"
                       decoration-danger="status=='error'"
                       decoration-warning="status=='drift'">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="status"/>
                <field name="error" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_orc_audit_log_search" model="ir.ui.view">
        <field name="name">orc.audit.log.search</field>
        <field name="model">orc.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="action"/>
                <filter name="filter_ok" string="OK" domain="[('status', '=', 'ok')]"/>
                <filter name="filter_error" string="Error" domain="[('status', '=', 'error')]"/>
                <filter name="filter_drift" string="Drift" domain="[('status', '=', 'drift')]"/>
                <group expand="0" string="Group by">
                    <filter name="group_action" string="Action" context="{'group_by': 'action'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_orc_audit_log" model="ir.actions.act_window">
        <field name="name">ORC audit log</field>
        <field name="res_model">orc.audit.log</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_orc_audit_log_search"/>
    </record>
</odoo>
