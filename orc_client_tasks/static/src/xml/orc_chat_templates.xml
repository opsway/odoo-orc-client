<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Systray icon + unread badge + dropdown holding the task list.
         Hidden entirely when the user isn't orc_enabled. -->
    <t t-name="orc_client_tasks.OrcChatSystray">
        <div t-if="enabled" class="o_orc_chat_systray">
            <button type="button"
                    class="btn btn-link o_orc_chat_systray_btn"
                    t-on-click="onToggleDropdown"
                    title="ORC chats">
                <i class="fa fa-comments"/>
                <span t-if="badgeLabel"
                      class="o_orc_chat_badge"
                      t-esc="badgeLabel"/>
            </button>
            <div t-if="ui.dropdownOpen" class="o_orc_chat_dropdown">
                <OrcTaskListPopover onPicked.bind="onTaskPicked"/>
            </div>
        </div>
    </t>

    <!-- Task list + inline new-task composer. Rendered inside the
         systray dropdown; also standalone-friendly. -->
    <t t-name="orc_client_tasks.OrcTaskListPopover">
        <div class="o_orc_chat_popover">
            <div class="o_orc_chat_popover_header">
                <span class="o_orc_chat_popover_title">My ORC chats</span>
                <button type="button"
                        class="btn btn-sm btn-link o_orc_chat_compose_toggle"
                        t-on-click="onClickCompose"
                        t-att-title="ui.composerOpen ? 'Cancel' : 'New chat'">
                    <i t-att-class="ui.composerOpen ? 'fa fa-times' : 'fa fa-plus'"/>
                </button>
            </div>

            <div t-if="ui.composerOpen" class="o_orc_chat_composer">
                <textarea t-model="ui.composerText"
                          t-on-keydown="onComposerKeydown"
                          placeholder="Describe the issue — the agent will reply in chat."
                          rows="3"
                          class="form-control form-control-sm"/>
                <div class="o_orc_chat_composer_actions">
                    <button type="button"
                            class="btn btn-sm btn-primary"
                            t-on-click="onSubmitCompose"
                            t-att-disabled="ui.composerBusy or !ui.composerText.trim()">
                        <span t-if="!ui.composerBusy">Create</span>
                        <span t-else="">Creating…</span>
                    </button>
                </div>
            </div>

            <div class="o_orc_chat_popover_list">
                <t t-if="!tasks.length">
                    <p class="text-muted small p-3 mb-0">No ORC chats yet.</p>
                </t>
                <t t-foreach="tasks" t-as="task" t-key="task.room_id">
                    <button type="button"
                            class="o_orc_chat_task_row"
                            t-att-class="{'o_orc_chat_task_row_closed': task.status === 'closed'}"
                            t-on-click="() => this.onClickTask(task)">
                        <span class="o_orc_chat_task_title">
                            <t t-esc="taskLabel(task)"/>
                            <span t-if="isUnread(task)" class="o_orc_chat_unread_dot" title="Unread activity"/>
                        </span>
                        <span t-if="taskSubtitle(task)"
                              class="o_orc_chat_task_subtitle"
                              t-esc="taskSubtitle(task)"/>
                    </button>
                </t>
            </div>
        </div>
    </t>

    <!-- Dock: fixed-positioned overlay, empty when no windows open.
         Hidden entirely when orc_enabled is false. -->
    <t t-name="orc_client_tasks.OrcChatDock">
        <div t-if="enabled and visibleWindows.length" class="o_orc_chat_dock">
            <t t-foreach="visibleWindows" t-as="win" t-key="win.room_id">
                <OrcChatWindow roomId="win.room_id" folded="win.folded"/>
            </t>
        </div>
    </t>

    <!-- Single foldable chat window.
         - Header always visible (title, fold/unfold, close).
         - Body = hidden SSO form + iframe. The form auto-submits
           the nonce at mount time into the iframe.
         - When folded, body is collapsed (display:none) but not
           destroyed — iframe state (including SSE stream) is kept. -->
    <t t-name="orc_client_tasks.OrcChatWindow">
        <div class="o_orc_chat_window"
             t-att-class="{'o_orc_chat_window_folded': props.folded}">
            <div class="o_orc_chat_window_header"
                 t-on-click="onToggleFold">
                <span class="o_orc_chat_window_title">
                    <t t-esc="title"/>
                    <span t-if="unread" class="o_orc_chat_unread_dot"/>
                </span>
                <div class="o_orc_chat_window_actions">
                    <button type="button"
                            class="btn btn-sm btn-link"
                            t-on-click.stop="onToggleFold"
                            t-att-title="props.folded ? 'Unfold' : 'Fold'">
                        <i t-att-class="props.folded ? 'fa fa-chevron-up' : 'fa fa-chevron-down'"/>
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-link"
                            t-on-click.stop="onClose"
                            title="Close">
                        <i class="fa fa-times"/>
                    </button>
                </div>
            </div>
            <div class="o_orc_chat_window_body">
                <div t-if="ui.loading and !ui.error" class="o_orc_chat_window_loading">
                    Opening chat…
                </div>
                <div t-if="ui.error" class="o_orc_chat_window_error">
                    <strong>Couldn't open chat.</strong>
                    <div class="small text-muted mt-1" t-esc="ui.error"/>
                </div>
                <!-- The nonce-POST target name is shared between the
                     iframe `name` and the form `target`. -->
                <iframe t-if="ui.ssoUrl"
                        t-ref="iframe"
                        t-att-name="ui.frameName"
                        t-on-load="onIframeLoad"
                        src="about:blank"
                        sandbox="allow-forms allow-scripts allow-same-origin allow-popups"
                        class="o_orc_chat_iframe"/>
                <form t-if="ui.ssoUrl and ui.ssoNonce"
                      t-ref="form"
                      method="POST"
                      t-att-action="ui.ssoUrl"
                      t-att-target="ui.frameName"
                      style="display:none;">
                    <input type="hidden" name="nonce" t-att-value="ui.ssoNonce"/>
                </form>
            </div>
        </div>
    </t>

</templates>
