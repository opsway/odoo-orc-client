<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Seed the embed theme parameter so it's discoverable in
        Settings → Technical → System Parameters. ``noupdate="1"`` so
        the seeded value is created once on install and admin edits
        survive module upgrades.
    -->
    <data noupdate="1">
        <record id="orc_embed_theme_param" model="ir.config_parameter">
            <field name="key">orc_client_tasks.embed_theme</field>
            <field name="value">light</field>
        </record>
    </data>
</odoo>
