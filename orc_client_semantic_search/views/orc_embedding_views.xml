<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Settings → Technical → AI Semantic Search.

        The page renders the global singleton's provider fields in
        a header section and the per-model toggle list as a tree.
        "Test provider" + "Reindex all" are buttons on the global
        form.
    -->

    <record id="view_orc_embedding_config_form" model="ir.ui.view">
        <field name="name">orc.embedding.config.form</field>
        <field name="model">orc.embedding.config</field>
        <field name="arch" type="xml">
            <form string="AI Semantic Search Config">
                <header attrs="{'invisible': [('is_global', '=', False)]}">
                    <button name="action_test_provider"
                            type="object"
                            string="Test provider"
                            class="btn-primary"/>
                    <button name="action_reindex_all"
                            type="object"
                            string="Reindex all"
                            class="btn-secondary"
                            confirm="This will drop the index for every enabled model and re-embed every record. Costs money. Continue?"/>
                </header>
                <sheet>
                    <field name="is_global" invisible="1"/>
                    <group attrs="{'invisible': [('is_global', '=', False)]}" string="Provider">
                        <field name="provider_kind"/>
                        <field name="provider_url"/>
                        <field name="provider_api_key" password="True"/>
                        <field name="provider_model"/>
                        <field name="vector_dim"/>
                        <field name="cron_interval_minutes"/>
                        <field name="daily_token_cap"/>
                    </group>
                    <group attrs="{'invisible': [('is_global', '=', True)]}" string="Indexed model">
                        <field name="model_name"/>
                        <field name="enabled"/>
                        <field name="text_field_path"/>
                        <field name="text_extractor"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_orc_embedding_config_tree" model="ir.ui.view">
        <field name="name">orc.embedding.config.tree</field>
        <field name="model">orc.embedding.config</field>
        <field name="arch" type="xml">
            <tree string="AI Semantic Search Config">
                <field name="is_global"/>
                <field name="model_name"/>
                <field name="enabled"/>
                <field name="text_field_path"/>
                <field name="text_extractor"/>
                <field name="provider_model"/>
            </tree>
        </field>
    </record>

    <record id="action_orc_embedding_config" model="ir.actions.act_window">
        <field name="name">AI Semantic Search</field>
        <field name="res_model">orc.embedding.config</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_orc_embedding_root"
              name="AI Semantic Search"
              parent="base.menu_custom"
              action="action_orc_embedding_config"
              sequence="50"/>

</odoo>
